<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Connection Settings" android:textStyle="bold" android:textSize="16sp" android:layout_marginTop="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="WiFi Mode" />
            <Switch android:id="@+id/sw_connection_mode" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <EditText android:id="@+id/et_drone_ip" android:layout_width="match_parent" android:layout_height="40dp" android:hint="Drone IP" android:text="192.168.1.100" android:layout_marginTop="8dp" />

        <EditText android:id="@+id/et_port" android:layout_width="match_parent" android:layout_height="40dp" android:hint="Port" android:text="8000" android:inputType="number" android:layout_marginTop="8dp" />

        <Button android:id="@+id/btn_connect" android:layout_width="match_parent" android:layout_height="48dp" android:text="Connect" android:layout_marginTop="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Flight Settings" android:textStyle="bold" android:textSize="16sp" android:layout_marginTop="16dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Stabilization" />
            <Switch android:id="@+id/sw_stabilization" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Advanced Mode" />
            <Switch android:id="@+id/sw_advanced_mode" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <EditText android:id="@+id/et_max_speed" android:layout_width="match_parent" android:layout_height="40dp" android:hint="Max Speed (m/s)" android:text="20" android:inputType="numberDecimal" />

        <EditText android:id="@+id/et_max_altitude" android:layout_width="match_parent" android:layout_height="40dp" android:hint="Max Altitude (m)" android:text="500" android:inputType="numberDecimal" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sensor Settings" android:textStyle="bold" android:textSize="16sp" android:layout_marginTop="16dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="GPS Enabled" />
            <Switch android:id="@+id/sw_gps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Motion Tracking" />
            <Switch android:id="@+id/sw_motion_tracking" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <Button android:id="@+id/btn_calibrate" android:layout_width="match_parent" android:layout_height="48dp" android:text="Calibrate IMU" android:layout_marginTop="8dp" />

        <Button android:id="@+id/btn_calibrate_compass" android:layout_width="match_parent" android:layout_height="48dp" android:text="Calibrate Compass" android:layout_marginTop="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="System" android:textStyle="bold" android:textSize="16sp" android:layout_marginTop="16dp" />

        <EditText android:id="@+id/et_firmware_version" android:layout_width="match_parent" android:layout_height="40dp" android:hint="Firmware Version" android:text="v1.0.0" android:enabled="false" />

        <Button android:id="@+id/btn_update_firmware" android:layout_width="match_parent" android:layout_height="48dp" android:text="Check Firmware Update" android:layout_marginTop="8dp" />

        <Button android:id="@+id/btn_factory_reset" android:layout_width="match_parent" android:layout_height="48dp" android:text="Factory Reset" android:layout_marginTop="8dp" android:backgroundTint="@android:color/holo_red_light" />

        <Button android:id="@+id/btn_about" android:layout_width="match_parent" android:layout_height="48dp" android:text="About" android:layout_marginTop="8dp" />

        <TextView android:id="@+id/tv_status" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="" android:layout_marginTop="16dp" android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
