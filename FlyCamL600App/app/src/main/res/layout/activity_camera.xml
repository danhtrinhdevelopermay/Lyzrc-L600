<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button android:id="@+id/btn_capture_photo" android:layout_width="match_parent" android:layout_height="48dp" android:text="Capture Photo" android:layout_marginBottom="8dp" />
            <Button android:id="@+id/btn_record" android:layout_width="match_parent" android:layout_height="48dp" android:text="Start Recording" android:layout_marginBottom="8dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gimbal Tilt" android:textStyle="bold" />
            <SeekBar android:id="@+id/sb_gimbal_tilt" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Zoom" android:textStyle="bold" />
            <SeekBar android:id="@+id/sb_zoom" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" />
            <TextView android:id="@+id/tv_zoom_level" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Zoom: 1.0x" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Resolution" android:textStyle="bold" />
            <Spinner android:id="@+id/spinner_resolution" android:layout_width="match_parent" android:layout_height="wrap_content" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FPS" android:textStyle="bold" />
            <Spinner android:id="@+id/spinner_fps" android:layout_width="match_parent" android:layout_height="wrap_content" />

            <RadioGroup android:layout_width="match_parent" android:layout_height="wrap_content">
                <RadioButton android:id="@+id/rb_jpeg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="JPEG" android:checked="true" />
                <RadioButton android:id="@+id/rb_raw" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RAW" />
            </RadioGroup>

            <TextView android:id="@+id/tv_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ready" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
